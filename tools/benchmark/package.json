{
	"name": "@coulis/benchmark",
	"version": "0.0.0",
	"private": "true",
	"description": "Benchmark suite for coulis",
	"keywords": [],
	"license": "MIT",
	"author": "Ayoub Adib <adbayb@gmail.com>",
	"type": "module",
	"exports": {
		"./browser": {
			"source": "./src/cases/browser.tsx",
			"default": "./dist/browser.js"
		}
	},
	"scripts": {
		"benchmark": "pnpm benchmark:browser && pnpm benchmark:server",
		"benchmark:browser": "quickbundle build --minification && playwright test ./src/playwright.spec.ts --headed",
		"benchmark:server": "node ./src/cases/server.spec.ts"
	},
	"devDependencies": {
		"@emotion/css": "11.13.5",
		"@emotion/server": "11.11.0",
		"coulis": "workspace:*",
		"playwright": "1.60.0",
		"quickbundle": "3.0.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"styled-components": "6.4.2",
		"tinybench": "6.0.2",
		"tsx": "4.22.3",
		"typescript": "6.0.3"
	}
}
